{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/api/upload-image", "destination": "/api/upload-image.js" },
    { "source": "/api/delete-image", "destination": "/api/delete-image.js" },
    { "source": "/((?!api/).*)", "destination": "/arya.html" }
  ]
}
